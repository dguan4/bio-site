# Your GitHub username (used to fetch profile, repos, and activity)
NEXT_PUBLIC_GITHUB_USERNAME=your-github-username

# GitHub personal access token — required for the contribution calendar heatmap
# and to avoid rate limiting (60 req/hr unauthenticated vs 5000 req/hr authenticated)
# Create one at https://github.com/settings/tokens (needs no special scopes for public data)
GITHUB_TOKEN=ghp_...

# Vercel KV — optional, used to cache GitHub API responses for 1 hour
# If omitted, data is fetched fresh on every request (fine for local dev)
KV_REST_API_URL=https://your-kv-instance.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token

# Secret used to authenticate on-demand cache revalidation via /api/revalidate
# Set to any random string (e.g. openssl rand -hex 32)
REVALIDATE_SECRET=your-revalidate-secret

# URL for the flashcards iframe on the Flashcards tab
NEXT_PUBLIC_FLASHCARD_URL=https://your-flashcard-app-url
